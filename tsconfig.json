{
  "compilerOptions": {
    /* === 编译输出 === */
    "outDir": "./dist",
    "rootDir": ".",

    /* === 环境设置 === */
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "esnext",
    "types": [],

    /* === 严格模式 === */
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true,

    /* === 源码映射（调试用，按需开启） === */
    // "sourceMap": true,
    // "declaration": true,
    // "declarationMap": true,
  },
  "include": [
    "api/**/*.ts",
    "bot_manager/**/*.ts",
    "storage/**/*.ts",
    "system/**/*.ts",
    "type/**/*.ts",
    "utils/**/*.ts",
    "index.ts",
    "app.ts",
  ],
  "exclude": [
    "node_modules",
    "dist",
    "bots",
    "configs",
    "v2旧版本功能参考"
  ]
}
