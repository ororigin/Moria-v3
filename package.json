{
  "name": "moria-v3",
  "version": "1.0.0",
  "main": "dist/index.js",
  "scripts": {
    "clean": "node -e \"const fs=require('fs'); ['dist','bots/dist'].forEach(d=>fs.rmSync(d,{recursive:true,force:true}))\"",
    "build": "tsc",
    "build:bots": "cd bots && tsc",
    "build:bots:prod": "cd bots && tsc --project tsconfig.prod.json",
    "rebuild": "npm run clean && npm run build",
    "watch:bots": "cd bots && tsc --watch",
    "dev:bots": "concurrently \"npm run watch:bots\" \"npm run serve:bots\"",
    "serve:bots": "nodemon --watch bots/dist ./bots/dist/bot.js",
    "start": "node dist/index.js",
    "dev": "ts-node index.ts"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/systeminformation": "^3.23.1",
    "concurrently": "^9.2.1",
    "mineflayer": "^4.37.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "resolve-tspaths": "^0.8.23",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2"
  },
  "type": "module",
  "dependencies": {
    "@types/archiver": "^7.0.0",
    "archiver": "^8.0.0",
    "dayjs": "^1.11.20",
    "env-paths": "^4.0.0",
    "fastify": "^5.8.5",
    "fs": "^0.0.1-security",
    "systeminformation": "^5.31.7",
    "zod": "^4.4.3"
  }
}
